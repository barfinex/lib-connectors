{
  "name": "@barfinex/connectors",
  "version": "0.0.0-development",
  "private": false,
  "description": "Connectors module for the Barfinex ecosystem. Provides integration with external market data providers (Binance, Alpaca, etc.), including REST/HTTP requests, candle transformation, and real-time data access via NestJS services.",
  "author": "Barfinex",
  "license": "MIT",
  "homepage": "https://github.com/barfinex/lib-connectors#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/barfinex/lib-connectors.git"
  },
  "bugs": {
    "url": "https://github.com/barfinex/lib-connectors/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsc -p tsconfig.app.json",
    "rebuild": "npm run clean && npm run build",
    "release": "semantic-release"
  },
  "keywords": [
    "barfinex",
    "connectors",
    "nestjs",
    "nestjs-module",
    "typescript",
    "trading",
    "market-data",
    "binance",
    "alpaca",
    "candle",
    "order",
    "crypto",
    "stocks",
    "integration",
    "http",
    "rxjs",
    "websocket",
    "exchange"
  ],
  "dependencies": {
    "@barfinex/types": "1.0.14",
    "@barfinex/utils": "1.0.1"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/axios": "^3.0.0",
    "rxjs": "^7.8.1",
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "rimraf": "^5.0.5",
    "semantic-release": "^24.1.0",
    "@semantic-release/npm": "^12.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/release-notes-generator": "^14.0.0",
    "@types/node": "^20.11.30",
    "@nestjs/common": "^10.0.0",
    "@nestjs/axios": "^3.0.0",
    "rxjs": "^7.8.1",
    "axios": "^1.7.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "release": {
    "branches": [
      "main"
    ]
  }
}
