{
  "name": "@barfinex/connectors",
  "version": "0.0.0-development",
  "private": false,
  "description": "Connectors module for the Barfinex ecosystem. Provides integration with external market data providers (Binance, Alpaca, Tinkoff, etc.) via NestJS.",
  "author": "Barfinex",
  "license": "MIT",
  "homepage": "https://github.com/barfinex/lib-connectors#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/barfinex/lib-connectors.git"
  },
  "bugs": {
    "url": "https://github.com/barfinex/lib-connectors/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "build": "tsc -p tsconfig.app.json",
    "build:npm": "tsc -p tsconfig.build.json",
    "rebuild": "npm run clean && npm run build",
    "release": "semantic-release"
  },
  "keywords": [
    "barfinex",
    "connectors",
    "nestjs",
    "nestjs-module",
    "typescript",
    "trading",
    "market-data",
    "binance",
    "alpaca",
    "tinkoff",
    "ccxt",
    "integration",
    "exchange"
  ],
  "dependencies": {
    "@barfinex/types": "latest",
    "@barfinex/utils": "latest"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/axios": "^3.0.0",
    "rxjs": "^7.8.1",
    "axios": "^1.7.0",
    "@master-chief/alpaca": "*",
    "ccxt": "*",
    "tinkoff-invest-api": "*"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "rimraf": "^5.0.5",
    "semantic-release": "^24.1.0",
    "@semantic-release/npm": "^12.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/release-notes-generator": "^14.0.0",
    "@types/node": "^20.11.30",
    "@nestjs/common": "^10.0.0",
    "@nestjs/axios": "^3.0.0",
    "rxjs": "^7.8.1",
    "axios": "^1.7.0",
    "@master-chief/alpaca": "^6.0.0",
    "ccxt": "^4.2.0",
    "tinkoff-invest-api": "^2.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "release": {
    "branches": [
      "main"
    ]
  }
}